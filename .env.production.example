# Hetzner Cloud Production Environment Template
# Copy this file to .env.production on the server and fill in strong secrets.
# NEVER commit the filled .env.production file to version control.

# Application configuration
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# Database configuration — generate a strong random password
# e.g., openssl rand -base64 32
POSTGRES_DB=rmias
POSTGRES_USER=rmias
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://rmias:change_me_in_production@db:5432/rmias

# Raw payload storage path (internal container path)
# Mounted to host persistent volume
RAW_PAYLOAD_STORAGE_PATH=/data/raw_payloads

# Security — generate a strong random API key
# e.g., python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change_me_to_a_long_random_secret
MAX_UPLOAD_BYTES=10485760   # 10 MB
RATE_LIMIT_RPM=30           # per-IP requests per minute on rate-limited endpoints

# Interactive API docs (/docs, /redoc, /openapi.json) are automatically hidden
# when APP_ENV=production. Set true only if you deliberately want them public.
ENABLE_DOCS_IN_PRODUCTION=false

# Optional HTTP Basic auth in front of the /admin SPA.
# Leave BOTH blank to keep /admin open (default). Set BOTH to require login.
# e.g., python3 -c "import secrets; print(secrets.token_urlsafe(24))"
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=

# Raw payload retention in days. 0 = keep forever (default). When > 0, run
# `docker exec rmias-app-1 python -m app.tools.prune_raw_payloads` (e.g. via
# host cron) to delete on-disk payloads older than this many days.
RAW_PAYLOAD_RETENTION_DAYS=0

# Background Scheduler & Collectors (Safety switches — must default to false)
# Enable explicitly only after validating each source and parser.
SCHEDULER_ENABLED=false
ENABLE_NOVA_COLLECTOR=false
ENABLE_KIIS_COLLECTOR=false
ENABLE_CAPITAL_COLLECTOR=false
ENABLE_NIGHTLY_RECONCILIATION=false

# Extracted collectors (EXTRACT-1B) — all disabled by default.
# DB station/source records (EXTRACT-2) required before enabling any of these.
ENABLE_BBC_RADIO1_COLLECTOR=false
ENABLE_HEART_COLLECTOR=false
ENABLE_Z100_COLLECTOR=false
ENABLE_WKSC_COLLECTOR=false
ENABLE_IHEART_TOP_SONGS=false

# Proxy rotation for IP cycling (optional but recommended in production)
# Comma-separated list of proxy URLs: http://, socks5://, socks5h://
PROXY_URLS=

# S3 / Object Storage Configuration (Optional, falls back to local filesystem if endpoint is empty)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=rmias-raw-payloads
S3_REGION=eu-central-1

# Spotify Metadata Enrichment Configuration
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://tenxradar.com/api/auth/spotify/callback
SPOTIFY_API_BASE_URL=https://api.spotify.com/v1
SPOTIFY_TOKEN_URL=https://accounts.spotify.com/api/token
SPOTIFY_METADATA_ENRICHMENT_ENABLED=false
SPOTIFY_MATCH_CONFIDENCE_THRESHOLD=0.80
SPOTIFY_REQUEST_TIMEOUT_SECONDS=10
SPOTIFY_MAX_RETRIES=2
SPOTIFY_TOKEN_CACHE_SECONDS=3300

# MusicBrainz & Cover Art Archive Integration
MUSICBRAINZ_API_BASE_URL=https://musicbrainz.org/ws/2
MUSICBRAINZ_USER_AGENT=TenXRadar/1.0 (https://tenxradar.com/contact)
MUSICBRAINZ_RATE_LIMIT_PER_SECOND=1
MUSICBRAINZ_DEFAULT_FORMAT=json
COVER_ART_ARCHIVE_BASE_URL=https://coverartarchive.org
MUSICBRAINZ_METADATA_ENRICHMENT_ENABLED=false

