# -------------------------------------------------------
# RMIAS environment configuration — copy to .env and fill
# -------------------------------------------------------

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (Docker Compose default — change PASSWORD in production)
POSTGRES_DB=rmias
POSTGRES_USER=rmias
POSTGRES_PASSWORD=change_me_in_production
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://rmias:change_me_in_production@db:5432/rmias

# Storage — path inside the container; mount a named volume in production
RAW_PAYLOAD_STORAGE_PATH=/data/raw_payloads

# Security
MAX_UPLOAD_BYTES=10485760   # 10 MB
RATE_LIMIT_RPM=30           # per-IP requests per minute on rate-limited endpoints
API_KEY=                    # empty = auth disabled (dev only)

# Interactive docs auto-hidden when APP_ENV=production; force on with true
ENABLE_DOCS_IN_PRODUCTION=false

# Optional HTTP Basic auth for /admin — set BOTH to enable, blank = open (dev)
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=

# Raw payload retention in days (0 = keep forever)
RAW_PAYLOAD_RETENTION_DAYS=0

# Master scheduler gate — must be true before any collector runs
SCHEDULER_ENABLED=false

# Nova 96.9 collectors (enable after VAL-* passes for each source)
ENABLE_NOVA_COLLECTOR=false                 # Radiowave diary (primary, cron 16:00 UTC)
ENABLE_NOVA_RADOXO_COLLECTOR=false          # radoxo.com playlist (secondary, every 4h)
ENABLE_NOVA_RADIO_AUSTRALIA_COLLECTOR=false # radio-australia.org chart (tertiary, cron 08:00 UTC)

# Capital FM UK collectors
ENABLE_CAPITAL_COLLECTOR=false              # Online Radio Box (primary, every 15min)
ENABLE_CAPITAL_UKRADIOLIVE_COLLECTOR=false  # ukradiolive.com (secondary, every 15min)

# KIIS-FM 102.7 Los Angeles collectors
ENABLE_KIIS_IHEART_WEB_COLLECTOR=false      # iHeart recently-played (primary, every 15min)
ENABLE_KIIS_RADIOWAVE_COLLECTOR=false       # Radiowave diary (secondary, cron 09:00 UTC)

# Nightly automation (enable once collectors are producing play events)
ENABLE_NIGHTLY_RECONCILIATION=false         # Deduplication run (cron 17:00 UTC)
ENABLE_NIGHTLY_REPORT_GENERATION=false      # Daily report builder (cron 18:00 UTC)
