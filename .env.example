# -------------------------------------------------------
# RMIAS environment configuration — copy to .env and fill
# -------------------------------------------------------

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (Docker Compose default — change PASSWORD in production)
POSTGRES_DB=rmias
POSTGRES_USER=rmias
POSTGRES_PASSWORD=change_me_in_production
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://rmias:change_me_in_production@db:5432/rmias

# Storage — path inside the container; mount a named volume in production
RAW_PAYLOAD_STORAGE_PATH=/data/raw_payloads

# Security
MAX_UPLOAD_BYTES=10485760   # 10 MB
RATE_LIMIT_RPM=30           # per-IP requests per minute on rate-limited endpoints
API_KEY=                    # empty = auth disabled (dev only)

# Interactive docs auto-hidden when APP_ENV=production; force on with true
ENABLE_DOCS_IN_PRODUCTION=false

# Optional HTTP Basic auth for /admin — set BOTH to enable, blank = open (dev)
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=

# Raw payload retention in days (0 = keep forever)
RAW_PAYLOAD_RETENTION_DAYS=0

# Scheduler and Collector safety switches (default false)
SCHEDULER_ENABLED=false
ENABLE_NOVA_COLLECTOR=false
ENABLE_KIIS_COLLECTOR=false
ENABLE_CAPITAL_COLLECTOR=false
ENABLE_NIGHTLY_RECONCILIATION=false
