# -------------------------------------------------------
# RMIAS environment configuration — copy to .env and fill
# -------------------------------------------------------

# ── Application ────────────────────────────────────────
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
# Public-facing base URL — used to build absolute links in emails (e.g. unsubscribe).
# No trailing slash.  Example: https://rmias.shopgoldplus.com
BASE_URL=

# ── Database (Docker Compose default) ─────────────────
# Change POSTGRES_PASSWORD before deploying to production.
POSTGRES_DB=rmias
POSTGRES_USER=rmias
POSTGRES_PASSWORD=change_me_in_production
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://rmias:change_me_in_production@db:5432/rmias

# ── Storage ────────────────────────────────────────────
# Path inside the container; mount a named volume in production.
RAW_PAYLOAD_STORAGE_PATH=/data/raw_payloads

# ── Security ───────────────────────────────────────────
# REQUIRED in production: set a strong random value (e.g. openssl rand -hex 32)
# Leave empty to disable auth in development.
API_KEY=

# Comma-separated allowed CORS origins. Leave empty to allow all origins (*).
# Example: https://admin.example.com,https://app.example.com
CORS_ORIGINS=

MAX_UPLOAD_BYTES=10485760   # 10 MB
RATE_LIMIT_RPM=30           # per-IP requests per minute on rate-limited endpoints

# ── Email / SMTP (ZeptoMail) ───────────────────────────
# Leave SMTP_HOST blank to run in dry-run mode (emails logged, not sent).
#
# ZeptoMail SMTP settings — fill in your credentials from the ZeptoMail dashboard.
# The username is always the literal string "emailapikey"; the password is your
# ZeptoMail API key.  SMTP_FROM_EMAIL must match a sender address verified in
# your ZeptoMail account.
SMTP_HOST=smtp.zeptomail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=emailapikey
SMTP_PASSWORD=             # ← ZeptoMail SMTP token from Mail Agents dashboard
SMTP_FROM_EMAIL=reports@shopgoldplus.com
SMTP_FROM_NAME=RMIAS Radio Reports

# ── Trend Alerts (webhook events) ──────────────────────
# Minimum plays in 7 days to trigger a song.trending webhook event.
# The event fires only on the first night the threshold is crossed (edge-triggered).
TREND_PLAYS_THRESHOLD=50

# Minimum plays in a song's first 7-day window to fire song.new_entry.
TREND_NEW_ENTRY_PLAYS=10

# ── Sentry error & performance monitoring ─────────────
# Leave SENTRY_DSN blank to disable Sentry (safe default for development).
# Get your DSN from https://sentry.io → Project → Settings → Client Keys.
SENTRY_DSN=
# Fraction of transactions captured for performance monitoring (0.0 – 1.0).
# 0.1 = 10 % sampled (recommended for production). 1.0 = all (dev only).
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── S3 / Hetzner Object Storage ────────────────────────
# Leave blank to use local filesystem storage instead of S3.
S3_ENDPOINT_URL=            # e.g. https://fsn1.your-objectstorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=rmias-raw-payloads
S3_REGION=eu-central-1

# ── Proxy rotation ─────────────────────────────────────
# Comma-separated list of proxy URLs for outbound HTTP requests (optional).
# Example: http://user:pass@proxy1:8080,socks5://proxy2:1080
PROXY_URLS=

# ── Observability ──────────────────────────────────────
# PgHero — PostgreSQL performance dashboard (http://localhost:8081)
# HTTP basic-auth credentials for the PgHero web UI.
PGHERO_USERNAME=admin
PGHERO_PASSWORD=          # ← set a strong password in production
# postgres:// URL for PgHero (same DB as the app, but using the postgres:// driver prefix).
# Must match POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB above.
PGHERO_DATABASE_URL=postgres://rmias:change_me_in_production@db:5432/rmias

# Grafana — log explorer & dashboards (http://localhost:3000)
# Admin password for the Grafana web UI (username is always "admin").
GRAFANA_PASSWORD=         # ← set a strong password in production

# Uptime Kuma (http://localhost:3001) — no env vars required; create your
# admin account on first visit and add monitors through the web UI.
